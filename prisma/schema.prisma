generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}
enum Priority {
  LOW
  MEDIUM
  HIGH
}
enum VaiTro {
  HocVien
  Admin
}

model User {
  id          Int       @id @default(autoincrement())
  hoTen       String
  email       String?   @unique
  sdt         String?   @unique
  ngaySinh    DateTime?
  password    String?
  vaiTro      VaiTro
  ngayTao     DateTime  @default(now())
  ngayCapNhat DateTime  @updatedAt

  HocVien     HocVien?
  Admin       Admin?
}

model HocVien {
  id   Int  @id
  User User @relation(fields: [id], references: [id], onDelete: Cascade)
  ThoiGianBieu ThoiGianBieu[]
  Todo Todo[]
}

model Admin {
  id   Int  @id
  User User @relation(fields: [id], references: [id], onDelete: Cascade)
}

model ThoiGianBieu {
  id        Int      @id @default(autoincrement())
  tieuDe    String
  batDau    DateTime
  ketThuc   DateTime
  moTa      String?
  
  hocVienId Int 
  hocVien   HocVien  @relation(fields: [hocVienId], references: [id], onDelete: Cascade)

  ngayTao     DateTime @default(now())
  ngayCapNhat DateTime @updatedAt
}
model Todo {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      Boolean  @default(false)
  priority    Priority @default(MEDIUM)
  targetDate  DateTime // Ngày cụ thể gắn với Todo
  
  hocVienId   Int
  hocVien     HocVien  @relation(fields: [hocVienId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([targetDate]) // Đánh index để query theo ngày cực nhanh
}