generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  // Không đặt url ở đây nữa
}

enum VaiTro {
  HocVien
  Admin
}

model User {
  id          Int       @id @default(autoincrement())
  hoTen       String
  email       String?   @unique
  sdt         String?   @unique
  ngaySinh    DateTime?
  password    String?
  vaiTro      VaiTro
  ngayTao     DateTime  @default(now())
  ngayCapNhat DateTime  @updatedAt
  
  HocVien     HocVien?
  Admin       Admin?
}

model HocVien {
  id   Int  @id
  User User @relation(fields: [id], references: [id])
}

model Admin {
  id   Int  @id
  User User @relation(fields: [id], references: [id])
}