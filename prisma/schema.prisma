generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- QUẢN LÝ NGƯỜI DÙNG ---

model user {
  id          Int               @id @default(autoincrement())
  hoTen       String
  email       String?           @unique(map: "User_email_key")
  sdt         String?           @unique(map: "User_sdt_key")
  ngaySinh    DateTime?
  password    String?
  vaiTro      user_vaiTro
  ngayTao     DateTime          @default(now())
  ngayCapNhat DateTime          @updatedAt

  // Quan hệ đã khôi phục
  hocvien            hocvien?
  admin              admin?
  flashcardfolders   flashcardfolder[]
  flashcardhistories flashcardhistory[]
}

model hocvien {
  id   Int  @id
  user user @relation(fields: [id], references: [id], onDelete: Cascade)

  // Quan hệ 1-n
  thoigianbieu thoigianbieu[]
  todos        todo[]
}

model admin {
  id   Int  @id
  user user @relation(fields: [id], references: [id], onDelete: Cascade)
}

// --- HỆ THỐNG FLASHCARD ---

model flashcardfolder {
  id        Int      @id @default(autoincrement())
  name      String
  userId    Int
  createdAt DateTime @default(now())

  // Quan hệ đã khôi phục
  user               user               @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcards         flashcard[]
  flashcardhistories flashcardhistory[]

  @@index([userId], map: "FlashcardFolder_userId_fkey")
}

model flashcard {
  id        Int     @id @default(autoincrement())
  front     String
  back      String
  isStarred Boolean @default(false)
  folderId  Int

  // Quan hệ
  folder flashcardfolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([folderId], map: "Flashcard_folderId_fkey")
}

model flashcardhistory {
  id             Int      @id @default(autoincrement())
  score          Float
  totalQuestions Int
  correctAnswers Int
  timeSpent      Int
  folderId       Int
  userId         Int
  createdAt      DateTime @default(now())

  // Quan hệ
  folder flashcardfolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user   user            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([folderId], map: "FlashcardHistory_folderId_fkey")
  @@index([userId], map: "FlashcardHistory_userId_fkey")
}

// --- QUẢN LÝ HỌC TẬP ---

model thoigianbieu {
  id          Int      @id @default(autoincrement())
  tieuDe      String
  batDau      DateTime
  ketThuc     DateTime
  moTa        String?
  hocVienId   Int
  ngayTao     DateTime @default(now())
  ngayCapNhat DateTime @updatedAt

  hocvien hocvien @relation(fields: [hocVienId], references: [id], onDelete: Cascade)

  @@index([hocVienId], map: "ThoiGianBieu_hocVienId_fkey")
}

model todo {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  status      Boolean       @default(false)
  priority    todo_priority @default(MEDIUM)
  targetDate  DateTime
  hocVienId   Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  hocvien hocvien @relation(fields: [hocVienId], references: [id], onDelete: Cascade)

  @@index([hocVienId], map: "Todo_hocVienId_fkey")
  @@index([targetDate], map: "Todo_targetDate_idx")
}

// --- ENUMS ---

enum todo_priority {
  LOW
  MEDIUM
  HIGH
}

enum user_vaiTro {
  HocVien
  Admin
}