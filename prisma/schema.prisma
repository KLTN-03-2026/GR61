generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum VaiTro {
  HocVien
  Admin
}

model User {
  id          Int       @id @default(autoincrement())
  hoTen       String
  email       String?   @unique
  sdt         String?   @unique
  ngaySinh    DateTime?
  password    String?
  vaiTro      VaiTro
  ngayTao     DateTime  @default(now())
  ngayCapNhat DateTime  @updatedAt

  HocVien     HocVien?
  Admin       Admin?
}

model HocVien {
  id   Int  @id
  User User @relation(fields: [id], references: [id], onDelete: Cascade)
  ThoiGianBieu ThoiGianBieu[]
}

model Admin {
  id   Int  @id
  User User @relation(fields: [id], references: [id], onDelete: Cascade)
}

model ThoiGianBieu {
  id        Int      @id @default(autoincrement())
  tieuDe    String
  batDau    DateTime
  ketThuc   DateTime
  moTa      String?
  
  hocVienId Int 
  hocVien   HocVien  @relation(fields: [hocVienId], references: [id], onDelete: Cascade)

  ngayTao     DateTime @default(now())
  ngayCapNhat DateTime @updatedAt
}