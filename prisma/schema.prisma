generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                @id @default(autoincrement())
  hoTen              String
  email              String?            @unique(map: "User_email_key")
  sdt                String?            @unique(map: "User_sdt_key")
  ngaySinh           DateTime?
  password           String?
  vaiTro             User_vaiTro
  ngayTao            DateTime           @default(now())
  ngayCapNhat        DateTime           @updatedAt
  admin              Admin?
  flashcardfolders   FlashcardFolder[]
  flashcardhistories FlashcardHistory[]
  hocvien            Hocvien?
  auditLogs          AuditLog[]
  chatHistories      ChatHistory[]

  @@map("user")
}

model Hocvien {
  id           Int            @id
  documents    Document[]
  user         User           @relation(fields: [id], references: [id], onDelete: Cascade, map: "fk_hocvien_user_identity")
  notes        Note[]
  thoigianbieu ThoiGianBieu[]
  todos        Todo[]

  @@map("hocvien")
}

model Admin {
  id   Int  @id
  user User @relation(fields: [id], references: [id], onDelete: Cascade, map: "fk_admin_user_identity")

  @@map("admin")
}

model FlashcardFolder {
  id         Int                @id @default(autoincrement())
  name       String
  userId     Int
  createdAt  DateTime           @default(now())
  flashcards Flashcard[]
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  histories  FlashcardHistory[]

  @@index([userId], map: "FlashcardFolder_userId_fkey")
  @@map("flashcardfolder")
}

model Flashcard {
  id        Int             @id @default(autoincrement())
  front     String
  back      String
  isStarred Boolean         @default(false)
  folderId  Int
  folder    FlashcardFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([folderId], map: "Flashcard_folderId_fkey")
  @@map("flashcard")
}

model FlashcardHistory {
  id             Int             @id @default(autoincrement())
  score          Float
  totalQuestions Int
  correctAnswers Int
  timeSpent      Int
  details        Json?           
  folderId       Int
  userId         Int
  createdAt      DateTime        @default(now())
  
  folder         FlashcardFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([folderId], map: "FlashcardHistory_folderId_fkey")
  @@index([userId], map: "FlashcardHistory_userId_fkey")
  @@map("flashcardhistory")
}

model ThoiGianBieu {
  id          Int      @id @default(autoincrement())
  tieuDe      String
  batDau      DateTime
  ketThuc     DateTime
  moTa        String?
  hocVienId   Int
  ngayTao     DateTime @default(now())
  ngayCapNhat DateTime @updatedAt
  hocvien     Hocvien  @relation(fields: [hocVienId], references: [id], onDelete: Cascade)

  @@index([hocVienId], map: "ThoiGianBieu_hocVienId_fkey")
  @@map("thoigianbieu")
}

model Todo {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  status      Boolean       @default(false)
  priority    Todo_priority @default(MEDIUM)
  targetDate  DateTime
  hocVienId   Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  hocvien     Hocvien       @relation(fields: [hocVienId], references: [id], onDelete: Cascade)

  @@index([hocVienId], map: "Todo_hocVienId_fkey")
  @@index([targetDate], map: "Todo_targetDate_idx")
  @@map("todo")
}

model Document {
  id        Int      @id @default(autoincrement())
  title     String
  fileUrl   String   @db.Text
  fileType  String
  fileSize  String
  content   String?  @db.LongText
  userId    Int
  createdAt DateTime @default(now())
  hocvien   Hocvien  @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_document_hocvien")

  @@index([userId], map: "idx_document_userId")
  @@map("document")
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @db.LongText
  category  String   @default("KHÁC")
  isPinned  Boolean  @default(false)  
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  hocvien   Hocvien  @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_note_hocvien")

  @@index([userId], map: "idx_note_userId")
  @@map("note")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     
  userName  String?  
  action    String   
  table     String?  
  detail    String?  @db.Text 
  type      String   
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("auditlog")
}

model ChatHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  role      String   
  message   String   @db.LongText
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chathistory")
}

enum Todo_priority {
  LOW
  MEDIUM
  HIGH
}

enum User_vaiTro {
  HocVien
  Admin
}